{
  "version": 1,
  "settings": {
    "timezone": "Asia/Shanghai",
    "defaultProvider": "opencode",
    "cliCommands": {
      "opencode": "opencode",
      "codex": "codex",
      "claude": "claude"
    },
    "attachUrl": "http://127.0.0.1:4096",
    "autoAttach": true,
    "autoStartDaemon": false,
    "outputMode": "pretty",
    "maxConcurrentRuns": 1
  },
  "tasks": [
    {
      "name": "Hourly Heartbeat",
      "description": "Keep the default OpenCode session warm and collect a short workspace summary.",
      "type": "cron",
      "enabled": true,
      "schedule": {
        "cron": "0 * * * *",
        "timezone": "Asia/Shanghai"
      },
      "command": {
        "provider": "opencode",
        "mode": "prompt",
        "prompt": "Inspect the current workspace, summarize recent changes, and exit.",
        "workdir": "/path/to/project",
        "attachStrategy": "always",
        "extraArgs": [],
        "model": "",
        "agent": "",
        "title": "Hourly Heartbeat",
        "format": "pretty",
        "commandName": ""
      }
    },
    {
      "name": "Codex Release Gate",
      "description": "One-shot execution for a release day check via Codex.",
      "type": "once",
      "enabled": true,
      "schedule": {
        "at": "2026-03-20T09:00:00+08:00"
      },
      "command": {
        "provider": "codex",
        "mode": "prompt",
        "prompt": "Run a release readiness check and summarize blockers.",
        "workdir": "/path/to/project",
        "attachStrategy": "inherit",
        "extraArgs": [],
        "model": "",
        "agent": "",
        "title": "Release Gate",
        "format": "pretty",
        "commandName": ""
      }
    },
    {
      "name": "Claude Follow-up",
      "description": "Run once after a short delay via Claude Code.",
      "type": "delay",
      "enabled": true,
      "schedule": {
        "delayText": "45m"
      },
      "command": {
        "provider": "claude",
        "mode": "prompt",
        "prompt": "Check the workspace again and report what changed after the waiting period.",
        "workdir": "/path/to/project",
        "attachStrategy": "inherit",
        "extraArgs": [],
        "model": "",
        "agent": "",
        "title": "Delayed Follow-up",
        "format": "pretty",
        "commandName": ""
      }
    }
  ]
}
